pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "yourdockerhub/flask-monitoring"
        DOCKER_TAG = "latest"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/yourusername/cloud-native-monitoring-app.git'
            }
        }

        stage('SonarQube Code Quality') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    sonar-scanner \
                    -Dsonar.projectKey=flask-monitoring \
                    -Dsonar.sources=. \
                    -Dsonar.host.url=http://sonarqube:9000 \
                    -Dsonar.login=$SONAR_TOKEN
                    '''
                }
            }
        }

        stage('Trivy Filesystem Scan') {
            steps {
                sh 'trivy fs .'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE:$DOCKER_TAG .'
            }
        }

        stage('Docker Scout Scan') {
            steps {
                sh 'docker scout quickview $DOCKER_IMAGE:$DOCKER_TAG'
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image $DOCKER_IMAGE:$DOCKER_TAG'
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    docker push $DOCKER_IMAGE:$DOCKER_TAG
                    '''
                }
            }
        }

        stage('Update Kubernetes Manifest') {
            steps {
                sh '''
                sed -i "s|image: .*|image: $DOCKER_IMAGE:$DOCKER_TAG|" k8s/deployment.yaml
                '''
            }
        }

        stage('Push Manifest to GitOps Repo') {
            steps {
                sh '''
                git config --global user.email "jenkins@example.com"
                git config --global user.name "jenkins"

                git add k8s/deployment.yaml
                git commit -m "Updated image version"
                git push
                '''
            }
        }

    }

    post {

        success {
            mail to: 'yourmail@gmail.com',
            subject: "Pipeline Success",
            body: "Jenkins Pipeline completed successfully!"
        }

        failure {
            mail to: 'yourmail@gmail.com',
            subject: "Pipeline Failed",
            body: "Pipeline failed. Please check Jenkins."
        }

    }
}
